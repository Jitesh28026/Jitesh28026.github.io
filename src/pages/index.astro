---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Jitesh — Product Designer"
  description="Jitesh is a product designer based in Bengaluru, crafting thoughtful B2B experiences. Portfolio showcasing UX design, prototyping, and design systems work."
  noindex
>
  <main style="max-width: 480px; margin: 8rem auto; padding: 0 1.5rem;">
    <h1 style="font-family: 'Instrument Serif', serif; font-size: 2rem; font-style: italic; color: var(--text-primary); margin-bottom: 0.75rem;">
      Migration in progress.
    </h1>
    <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">
      This site is being rebuilt on Astro. The previous version is still
      available at the link below.
    </p>
    <a
      href="/legacy/index.html"
      style="color: var(--accent); text-decoration: none; font-weight: 500; border-bottom: 1px solid currentColor;"
    >
      View the legacy portfolio &rarr;
    </a>
  </main>
</BaseLayout>
