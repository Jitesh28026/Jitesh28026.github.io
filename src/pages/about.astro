---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import { Image } from 'astro:assets';
import jiteshPhoto from '../assets/about/jitesh-photo.jpg';
import oo01 from '../assets/about/20221225_070815.jpg';
import oo02 from '../assets/about/20240531_123240.jpg';
import oo03 from '../assets/about/20240601_191229.jpg';
import oo04 from '../assets/about/20240602_164725.jpg';
import oo05 from '../assets/about/20240603_161640.jpg';
import oo06 from '../assets/about/20240604_175951.jpg';
import oo07 from '../assets/about/20240605_113742.jpg';
import oo08 from '../assets/about/20240815_163722.jpg';
import oo09 from '../assets/about/20240816_173945.jpg';
import oo10 from '../assets/about/20250219_062728.jpg';
import oo11 from '../assets/about/20250515_184532.jpg';
import '../styles/about.css';

const polaroids = [
  { src: oo01, alt: 'Sitting by a hill-lined reservoir at dawn' },
  { src: oo02, alt: 'A plate of maggi held above a forest stream' },
  { src: oo03, alt: 'Sunset over a Himalayan campsite' },
  { src: oo04, alt: 'Snow peaks from a car window' },
  { src: oo05, alt: 'Terraced fields against distant mountains' },
  { src: oo06, alt: 'A white dog watching the hills' },
  { src: oo07, alt: 'On a wooden deck above the deodar pines' },
  { src: oo08, alt: 'Forested ridge under heavy clouds' },
  { src: oo09, alt: 'Power lines through misty hills' },
  { src: oo10, alt: 'A tall tower against a foggy dusk' },
  { src: oo11, alt: 'Bright sunburst behind dark clouds' },
];

const skills = [
  { label: 'Figma',                    gloss: 'home address.' },
  { label: 'Prototyping',              gloss: 'proof I wasn\'t lying.' },
  { label: 'UX Research',              gloss: 'asking until it gets uncomfortable.' },
  { label: 'Design Systems',           gloss: 'the part I\'d do for free.' },
  { label: 'Information Architecture', gloss: 'the closet I keep tidy.' },
  { label: 'HTML/CSS',                 gloss: 'reading the menu in its own language.' },
  { label: 'Product Strategy',         gloss: 'arguing my way to a smaller scope.' },
  { label: 'Agentic Workflows',        gloss: 'letting the bot have the boring half.' },
];
---

<BaseLayout
  title="About · Jitesh"
  description="Jitesh is a product designer based in Bengaluru. Learn about his process and approach to solving complex B2B problems."
>
  <Navbar />

  <section id="about" class="after-hours">
    <canvas class="ah-bg-canvas" data-ah-bg-canvas aria-hidden="true"></canvas>
    <div class="ah-headlights" data-headlights aria-hidden="true"></div>
    <div class="ah-timestamps" data-timestamps aria-hidden="true"></div>

    <div class="ah-container">
      <div class="ah-label" data-exhale>/ ABOUT</div>

      <h2 class="ah-heading" data-exhale data-exhale-delay="120">
        Designer who thinks <em class="ah-italic">in systems.</em>
      </h2>

      <div class="ah-body">
        <div class="ah-text-col">
          <p
            class="ah-paragraph"
            data-exhale
            data-exhale-delay="280"
            data-inner-voice="I do my best thinking when the Slack notifications stop."
          >
            I'm Jitesh, a product designer in Bengaluru, mostly working
            after everyone else has logged off.
          </p>

          <p
            class="ah-paragraph"
            data-exhale
            data-exhale-delay="420"
            data-inner-voice="I'm scared the easy problems would bore me."
          >
            I work on B2B problems where the edge cases outnumber the happy
            paths, and the stakeholders have opinions about everything
            except the user.
          </p>

          <p
            class="ah-paragraph"
            data-exhale
            data-exhale-delay="560"
            data-inner-voice="Hospitality with a cursor."
          >
            I think in systems the same way I think about hosting people:
            what makes someone feel welcomed, oriented, safe to look around.
            Most of design, for me, is just that.
          </p>

          <p
            class="ah-paragraph"
            data-exhale
            data-exhale-delay="700"
            data-inner-voice="Mostly the matchmaking."
          >
            Off the clock: planning trips I won't take, losing ranked
            matches, blaming the matchmaking.
          </p>
        </div>

        <aside class="ah-portrait-col" data-exhale data-exhale-delay="200">
          <div class="ah-portrait">
            <Image
              src={jiteshPhoto}
              alt="Jitesh, Product Designer"
              widths={[320, 640, 960]}
              sizes="(max-width: 768px) 70vw, 320px"
              loading="eager"
              decoding="sync"
              class="ah-portrait-img"
              style="width: 100%; height: 100%; object-fit: cover; display: block;"
            />
          </div>

          <dl class="ah-meta" data-idle-cursor>
            <div class="ah-meta-row">
              <dt>LOC</dt><dd>Bengaluru · 12.97° N</dd>
            </div>
            <div class="ah-meta-row">
              <dt>SINCE</dt><dd>02Y designing B2B</dd>
            </div>
            <div class="ah-meta-row">
              <dt>STATE</dt>
              <dd><span data-idle-state>thinking</span><span class="ah-cursor" aria-hidden="true">_</span></dd>
            </div>
          </dl>
        </aside>
      </div>

      <div class="ah-skills" data-stagger-quiet data-exhale data-exhale-delay="820">
        {skills.map((s) => (
          <span class="ah-chip">
            <span class="ah-chip-label">{s.label}</span>
            <span class="ah-chip-gloss" aria-hidden="true">{s.gloss}</span>
          </span>
        ))}
      </div>

      <div class="ah-closing" data-exhale data-exhale-delay="1000">
        <span class="ah-closing-time">01:47 · still here.</span>
      </div>
    </div>

    <div class="ah-drive-arc" data-drive-arc aria-hidden="true">
      <span class="ah-arc-label">DRIVE</span>
      <span class="ah-arc-track"><span class="ah-arc-fill"></span></span>
      <span class="ah-arc-time">00:00</span>
    </div>

    <section class="out-of-office" aria-labelledby="oo-label">
      <div class="oo-container">
        <h2 class="oo-label" id="oo-label" data-exhale>/ OUT OF OFFICE</h2>
      </div>

      <div class="oo-marquee" aria-label="Gallery of trip photographs">
        <div class="oo-track">
          {[...polaroids, ...polaroids].map((p, i) => (
            <figure class="oo-card" aria-hidden={i >= polaroids.length ? 'true' : 'false'}>
              <div class="oo-frame">
                <Image
                  src={p.src}
                  alt={i >= polaroids.length ? '' : p.alt}
                  widths={[280, 420, 560]}
                  sizes="(max-width: 778px) 200px, 280px"
                  loading="lazy"
                  decoding="async"
                  class="oo-img"
                />
              </div>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <div class="ah-quiet-break" aria-hidden="true"></div>

    <div class="aim-lab reveal aim-lab-reveal">
      <div class="aim-lab-grid">
        <div class="aim-lab-copy">
          <div class="section-label">AIM LAB</div>
          <p>
            When I'm not designing, I'm probably in a deathmatch. This is a
            15-second aim trainer. Don't embarrass yourself.
          </p>
        </div>
        <div class="aim-lab-panel">
          <div class="aim-lab-shell" id="aimLab" data-state="idle">
            <div class="aim-lab-head">
              <div>SCORE <strong id="aimScore">0</strong></div>
              <div>TIME <strong id="aimTime">15.0</strong></div>
            </div>
            <div class="aim-lab-stage" id="aimStage">
              <canvas class="aim-lab-canvas" id="aimCanvas" width="720" height="460"></canvas>
              <div class="aim-lab-overlay" id="aimOverlay">
                <div class="aim-lab-overlay-card">
                  <h3>Range Ready</h3>
                  <p>One target at a time. Fifteen seconds. Clean clicks only.</p>
                  <button class="aim-lab-button primary" id="aimStartButton" type="button">Start</button>
                </div>
              </div>
              <div class="aim-lab-results" id="aimResults" hidden>
                <div class="aim-lab-results-card">
                  <h3>Match Report</h3>
                  <div class="aim-lab-results-grid">
                    <div class="aim-lab-stat">
                      <span class="aim-lab-stat-label">Score</span>
                      <span class="aim-lab-stat-value" id="aimResultScore">0</span>
                    </div>
                    <div class="aim-lab-stat">
                      <span class="aim-lab-stat-label">Accuracy</span>
                      <span class="aim-lab-stat-value" id="aimResultAccuracy">0%</span>
                    </div>
                    <div class="aim-lab-stat">
                      <span class="aim-lab-stat-label">Avg Reaction</span>
                      <span class="aim-lab-stat-value" id="aimResultReaction">0ms</span>
                    </div>
                  </div>
                  <div class="aim-lab-verdict" id="aimVerdict">Needs warmup</div>
                  <button class="aim-lab-button" id="aimReplayButton" type="button">Play Again</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import '../scripts/aim-lab';
    import '../scripts/about-animations';
    import '../scripts/after-hours-canvas';
    import '../scripts/tilt';
  </script>

</BaseLayout>
