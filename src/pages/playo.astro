      var dir = 1, speed = 0.7, paused = reduce;
      ['pointerenter', 'pointerdown', 'touchstart', 'wheel'].forEach(function (ev) {
        el.addEventListener(ev, function () { paused = true; }, { passive: true });
      });
      el.addEventListener('pointerleave', function () { if (!reduce) paused = false; });
      function step() {
        if (!paused) {
          el.scrollTop += dir * speed;
          if (el.scrollTop + el.clientHeight >= el.scrollHeight - 1) dir = -1;
          else if (el.scrollTop <= 0) dir = 1;
