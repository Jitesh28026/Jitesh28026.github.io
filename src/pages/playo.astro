---
// Standalone Playo product teardown. Deliberately self-contained — its own
// visual identity (Roboto + Playo green), not the portfolio's terminal theme.
// Served at /playo. Images live in /public/playo/.
const canonical = 'https://jitesht.com/playo';
const description =
  "A product teardown of Playo: how the app routes a court's footwear rule through the one person it exists to make unnecessary — and the one field that fixes it.";
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Show up and play — a Playo teardown</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
<meta name="author" content="Jitesh Thakker">
<meta property="og:type" content="article">
<meta property="og:title" content="Show up and play — a Playo teardown">
<meta property="og:description" content={description}>
<meta property="og:url" content={canonical}>
<meta property="og:image" content="https://jitesht.com/playo/playo-venue-page.jpg">
<meta name="twitter:card" content="summary_large_image">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet">
<style is:global>
  :root{
    --green:#06A94E;
    --green-dark:#0B8C43;
    --green-tint:#E8F7EE;
    --slate:#2B3A40;
    --slate-2:#3A4C53;
    --blue:#0B6EE8;
    --amber:#F5A623;
    --flag:#D9483F;
    --ink:#1C1D1F;
    --ink-2:#5F6469;
    --ink-3:#8E9499;
    --line:#E4E6E8;
    --paper:#F2F3F4;
    --white:#fff;
  }

  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family:'Roboto',system-ui,sans-serif;
    -webkit-font-smoothing:antialiased;
    line-height:1.55;
  }
  .wrap{max-width:1080px;margin:0 auto;padding:0 20px;}

  /* ---------- eyebrow / utility type ---------- */
  .eyebrow{
    font-family:'Roboto Mono',monospace;
    font-size:11px;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:var(--ink-3);
    margin:0 0 14px;
  }

  /* ---------- hero: borrows the game-page header band ---------- */
  .hero{background:var(--slate);color:#fff;padding:34px 0 44px;}
  .hero .eyebrow{color:rgba(255,255,255,.5);}
  .hero h1{
    font-size:clamp(34px,6vw,58px);
    font-weight:900;
    letter-spacing:-.025em;
    line-height:1.02;
    margin:0 0 14px;
  }
  .hero h1 em{font-style:normal;color:var(--green);}
  .hero p{
    font-size:clamp(15px,2vw,18px);
    color:rgba(255,255,255,.74);
    max-width:56ch;
    margin:0;
  }
  .hero-meta{
    margin-top:26px;padding-top:18px;
    border-top:1px solid rgba(255,255,255,.14);
    font-family:'Roboto Mono',monospace;
    font-size:11.5px;letter-spacing:.06em;
    color:rgba(255,255,255,.46);
    display:flex;flex-wrap:wrap;gap:8px 22px;
  }

  /* ---------- receipt: the actual incident, as a fact block ---------- */
  .receipt{
    background:var(--white);
    border:1px solid var(--line);
    border-radius:12px;
    margin:-24px 0 0;
    padding:22px 24px;
    position:relative;
    box-shadow:0 6px 22px rgba(0,0,0,.07);
  }
  .receipt dl{margin:0;display:grid;grid-template-columns:150px 1fr;gap:9px 18px;}
  .receipt dt{
    font-family:'Roboto Mono',monospace;
    font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;
    color:var(--ink-3);padding-top:3px;
  }
  .receipt dd{margin:0;font-size:15px;}
  .receipt dd b{font-weight:700;}
  .receipt .flagged{color:var(--flag);font-weight:700;}

  /* ---------- sections ---------- */
  section{padding:56px 0;}
  h2{
    font-size:clamp(24px,3.4vw,34px);
    font-weight:900;letter-spacing:-.02em;line-height:1.14;
    margin:0 0 16px;max-width:22ch;
  }
  .lede{font-size:17px;color:var(--ink-2);max-width:64ch;margin:0 0 8px;}
  .lede + .lede{margin-top:14px;}
  .lede b{color:var(--ink);font-weight:700;}

  /* ---------- the two mocks: the signature ---------- */
  .stage{
    background:var(--slate);
    border-radius:16px;
    padding:32px 22px 26px;
    margin-top:34px;
  }
  .stage-grid{
    display:grid;
    grid-template-columns:repeat(2,minmax(0,1fr));
    gap:28px;
    max-width:800px;margin:0 auto;
  }
  .col-head{margin:0 0 12px;}
  .col-head .tag{
    display:inline-block;
    font-family:'Roboto Mono',monospace;
    font-size:10px;letter-spacing:.12em;text-transform:uppercase;
    padding:4px 9px;border-radius:4px;margin-bottom:8px;
  }
  .tag-now{background:rgba(217,72,63,.16);color:#F08079;}
  .tag-fix{background:rgba(6,169,78,.18);color:#4FD489;}
  .col-head h3{margin:0;font-size:15px;font-weight:700;color:#fff;}
  .col-head p{margin:4px 0 0;font-size:12.5px;color:rgba(255,255,255,.5);line-height:1.45;}

  /* phone */
  .phone{
    background:var(--paper);
    border-radius:14px;
    overflow:hidden;
    border:1px solid rgba(255,255,255,.1);
  }
  .ph-head{background:var(--slate-2);padding:12px 14px 15px;}
  .ph-bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
  .ph-bar svg{fill:none;stroke:#fff;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
  .ph-head h4{margin:0;font-size:20px;font-weight:700;color:#fff;letter-spacing:-.01em;}
  .ph-head span{font-size:11px;color:rgba(255,255,255,.66);}
  .ph-body{padding:10px;display:flex;flex-direction:column;gap:9px;}

  .card{background:var(--white);border-radius:9px;padding:11px;}
  .venue-row{display:flex;align-items:flex-start;gap:8px;}
  .venue-row .pin{width:13px;height:13px;flex:none;margin-top:2px;fill:var(--green);}
  .venue-row a{color:var(--green);font-weight:700;font-size:12.5px;text-decoration:underline;}
  .venue-row small{display:block;color:var(--green);font-size:10.5px;font-weight:500;}

  /* ad + upsell blocks, deliberately shown as-is */
  .ad{
    background:linear-gradient(105deg,#161A1D,#2C1F33);
    border-radius:9px;padding:13px;color:#fff;
  }
  .ad .live{
    font-family:'Roboto Mono',monospace;font-size:7.5px;letter-spacing:.1em;
    background:#111;color:#FF4B4B;padding:2px 5px;border-radius:2px;
  }
  .ad h5{margin:8px 0 0;font-size:13px;font-weight:700;line-height:1.25;}
  .ad h5 i{font-style:normal;color:#4FF08E;font-size:15px;}
  .ad .chip{display:inline-block;margin-top:8px;background:#4FF08E;color:#0A2417;font-size:8.5px;font-weight:700;padding:3px 7px;border-radius:3px;}

  .card h5{margin:0 0 9px;font-size:13.5px;font-weight:700;}
  .card-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:9px;}
  .card-head h5{margin:0;}
  .lock{width:12px;height:12px;stroke:var(--ink-3);fill:none;stroke-width:2;}
  .player{display:flex;align-items:center;gap:8px;}
  .avatar{width:26px;height:26px;border-radius:50%;background:#CFE3D6;flex:none;}
  .player .nm{font-size:11.5px;font-weight:500;}
  .pill{
    display:inline-block;border:1px solid var(--line);border-radius:20px;
    padding:2px 8px;font-size:9px;color:var(--ink-2);
  }
  .empty{font-size:10.5px;color:var(--ink-3);text-align:center;line-height:1.5;margin:0 0 9px;}
  .btn{
    display:block;width:100%;text-align:center;
    background:var(--green);color:#fff;border:0;border-radius:5px;
    padding:9px;font-family:inherit;font-size:10.5px;font-weight:700;
    letter-spacing:.09em;text-transform:uppercase;
  }
  .sports{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;}
  .sports div{border-radius:6px;height:38px;}
  .sports div:nth-child(1){background:#EFE0F7;}
  .sports div:nth-child(2){background:#D6F2E7;}
  .sports div:nth-child(3){background:#FCF1D2;}
  .sports div:nth-child(4){background:#D8F2E4;}
  .sports div:nth-child(5){background:#D6E8FA;}
  .sports div:nth-child(6){background:#EDE2F8;}
  .private{text-align:center;font-size:10px;color:var(--ink-3);font-style:italic;padding:2px 0 4px;}

  /* the flag markers */
  .flagline{
    display:flex;gap:7px;align-items:flex-start;
    background:rgba(217,72,63,.1);
    border-left:2px solid var(--flag);
    padding:6px 8px;border-radius:0 4px 4px 0;
    margin-top:9px;
  }
  .flagline > b{
    font-family:'Roboto Mono',monospace;color:#F08079;
    font-size:9px;letter-spacing:.06em;flex:none;padding-top:1px;
  }
  .flagline > span{font-size:10.5px;color:rgba(255,255,255,.72);line-height:1.42;}

  /* the proposed block */
  .prep{border:1.5px solid var(--green);background:var(--green-tint);}
  .prep .card-head h5{color:var(--green-dark);}
  .prep-venue{
    font-family:'Roboto Mono',monospace;font-size:8.5px;letter-spacing:.06em;
    color:var(--green-dark);text-transform:uppercase;
  }
  .rule{display:flex;align-items:center;gap:7px;padding:5px 0;font-size:11.5px;}
  .rule + .rule{border-top:1px solid rgba(6,169,78,.16);}
  .rule .ic{
    width:17px;height:17px;border-radius:4px;flex:none;
    display:grid;place-items:center;font-size:9px;font-weight:900;color:#fff;
  }
  .ic-no{background:var(--flag);}
  .ic-yes{background:var(--green);}
  .ic-opt{background:var(--amber);}
  .rule b{font-weight:700;}
  .rent{
    display:flex;justify-content:space-between;align-items:center;
    margin-top:9px;background:#fff;border-radius:5px;padding:7px 9px;
  }
  .rent span{font-size:10.5px;font-weight:500;}
  .rent em{font-style:normal;font-size:9.5px;color:var(--ink-3);display:block;}
  .rent .go{
    font-family:'Roboto Mono',monospace;font-size:8.5px;letter-spacing:.08em;
    color:var(--green);font-weight:500;border:1px solid var(--green);
    padding:3px 7px;border-radius:3px;
  }

  /* ---------- pipe: one source, four surfaces ---------- */
  .pipe{
    background:var(--white);border:1px solid var(--line);border-radius:12px;
    padding:26px 24px;margin-top:30px;
  }
  .pipe-src{
    border:1.5px dashed var(--green);border-radius:8px;
    padding:12px 14px;background:var(--green-tint);
    max-width:400px;
  }
  .pipe-src .eyebrow{margin:0 0 7px;color:var(--green-dark);}
  .pipe-src p{margin:0;font-size:13px;color:var(--ink-2);}
  .pipe-src p b{color:var(--ink);}
  .pipe-arrow{
    height:26px;width:1.5px;background:var(--line);margin:10px 0 10px 30px;
  }
  .surfaces{display:grid;grid-template-columns:repeat(auto-fit,minmax(148px,1fr));gap:10px;}
  .surf{border:1px solid var(--line);border-radius:8px;padding:12px;}
  .surf .n{
    font-family:'Roboto Mono',monospace;font-size:9.5px;letter-spacing:.08em;
    color:var(--green);display:block;margin-bottom:5px;
  }
  .surf h6{margin:0 0 4px;font-size:12.5px;font-weight:700;}
  .surf p{margin:0;font-size:11.5px;color:var(--ink-2);line-height:1.45;}
  .surf.new{border-color:var(--green);background:var(--green-tint);}

  /* ---------- callout ---------- */
  .quote{
    border-left:3px solid var(--green);
    padding:2px 0 2px 18px;margin:26px 0;
    max-width:60ch;
  }
  .quote p{margin:0;font-size:18px;font-weight:500;letter-spacing:-.01em;line-height:1.42;}
  .quote cite{
    display:block;margin-top:9px;font-style:normal;
    font-family:'Roboto Mono',monospace;font-size:10.5px;letter-spacing:.06em;color:var(--ink-3);
  }

  /* ---------- validate list ---------- */
  .checks{list-style:none;padding:0;margin:22px 0 0;max-width:70ch;}
  .checks li{
    display:flex;gap:14px;padding:14px 0;border-top:1px solid var(--line);
  }
  .checks li:last-child{border-bottom:1px solid var(--line);}
  .checks .q{
    font-family:'Roboto Mono',monospace;font-size:10px;letter-spacing:.08em;
    color:var(--ink-3);flex:none;width:34px;padding-top:3px;
  }
  .checks p{margin:0;font-size:14.5px;}
  .checks p b{font-weight:700;}
  .checks p span{display:block;color:var(--ink-2);font-size:13px;margin-top:2px;}

  /* ---------- footer ---------- */
  footer{background:var(--slate);color:rgba(255,255,255,.6);padding:34px 0;}
  footer p{margin:0;font-size:13px;max-width:62ch;}
  footer a{color:var(--green);text-decoration:none;font-weight:500;}
  footer a:hover{text-decoration:underline;}
  footer .sig{
    margin-top:16px;font-family:'Roboto Mono',monospace;
    font-size:11px;letter-spacing:.08em;color:rgba(255,255,255,.38);
  }

  /* real screenshotframing */
  .shot{border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,.12);background:#fff;}
  .shot img{display:block;width:100%;height:auto;}
  .shot-cap{
    margin:9px 0 0;font-family:'Roboto Mono',monospace;
    font-size:9px;letter-spacing:.08em;color:rgba(255,255,255,.38);text-align:center;
  }

  /* phone device: the real screenshot scrolls inside a fixed frame, so a
     very tall capture reads like you're scrolling the actual app. */
  .device{
    width:264px;max-width:100%;margin:0 auto;
    background:#0E1417;border-radius:30px;padding:8px;
    border:1px solid rgba(255,255,255,.14);
    box-shadow:0 18px 44px rgba(0,0,0,.4);
  }
  .device-screen{
    border-radius:22px;overflow:hidden;position:relative;
    height:500px;overflow-y:auto;
    scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.3) transparent;
    -webkit-overflow-scrolling:touch;
  }
  .device-screen::-webkit-scrollbar{width:4px;}
  .device-screen::-webkit-scrollbar-thumb{background:rgba(255,255,255,.3);border-radius:2px;}
  .device-screen img{display:block;width:100%;height:auto;}
  .device-cap{
    margin:11px 0 0;font-family:'Roboto Mono',monospace;
    font-size:9px;letter-spacing:.08em;color:rgba(255,255,255,.38);text-align:center;
  }
  .device-hint{display:block;margin-top:3px;font-size:8px;color:rgba(255,255,255,.28);letter-spacing:.05em;}

  /* scroll-depth figure */
  .scrollfig{
    display:grid;grid-template-columns:172px 1fr;gap:30px;align-items:start;
    background:var(--white);border:1px solid var(--line);border-radius:12px;
    padding:24px;margin-top:30px;
  }
  .strip{position:relative;}
  .strip img{display:block;width:100%;border-radius:5px;border:1px solid var(--line);}
  .mark{
    position:absolute;left:-4px;right:-4px;
    border:1.5px solid var(--flag);border-radius:4px;
    background:rgba(217,72,63,.12);
  }
  .mark b{
    position:absolute;right:calc(100% + 8px);top:0;
    font-family:'Roboto Mono',monospace;font-size:9px;letter-spacing:.06em;
    color:var(--flag);white-space:nowrap;
  }
  .figtext h6{margin:0 0 10px;font-size:15px;font-weight:700;}
  .figtext p{margin:0 0 12px;font-size:14px;color:var(--ink-2);line-height:1.6;}
  .figtext p b{color:var(--ink);font-weight:700;}
  .figtext .depth{
    font-family:'Roboto Mono',monospace;font-size:10.5px;letter-spacing:.07em;
    color:var(--flag);margin:0;
  }

  /* the diff: two blobs, same venue */
  .diff{
    background:var(--white);border:1px solid var(--line);border-radius:12px;
    padding:24px;margin-top:30px;
  }
  .diff > h6{margin:0 0 4px;font-size:17px;font-weight:900;letter-spacing:-.015em;}
  .diff > .sub{margin:0 0 20px;font-size:13.5px;color:var(--ink-2);}
  .diff-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  .blob{border:1px solid var(--line);border-radius:8px;padding:14px;}
  .blob .src{
    display:block;font-family:'Roboto Mono',monospace;
    font-size:9px;letter-spacing:.1em;text-transform:uppercase;
    color:var(--ink-3);margin-bottom:10px;
  }
  .blob ul{list-style:none;margin:0;padding:0;}
  .blob li{
    font-size:12.5px;padding:5px 0;color:var(--ink);
    border-top:1px solid #F0F1F2;line-height:1.4;
  }
  .blob li:first-child{border-top:0;}
  .blob li.only{color:var(--flag);font-weight:700;}
  .blob li.miss{
    color:var(--ink-3);font-family:'Roboto Mono',monospace;
    font-size:10.5px;letter-spacing:.03em;background:rgba(217,72,63,.07);
  }
  .blob .note{
    margin:11px 0 0;padding-top:9px;border-top:1px solid var(--line);
    font-size:11.5px;color:var(--ink-3);line-height:1.45;
  }
  .diff .verdict{
    margin:18px 0 0;padding-top:16px;border-top:1px solid var(--line);
    font-size:14.5px;color:var(--ink-2);line-height:1.6;
  }
  .diff .verdict b{color:var(--ink);font-weight:700;}

  /* rule chips (mirrors the Amenities row) */
  .chips{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:9px;}
  .chip-r{
    display:inline-block;white-space:nowrap;vertical-align:middle;
    font-size:10px;font-weight:700;padding:4px 8px;border-radius:20px;
    border:1px solid transparent;letter-spacing:.01em;line-height:1.3;
  }
  .chip-no{background:#FDE9E8;border-color:#F3B9B5;color:#B03A32;}
  .chip-yes{background:#E4F6EC;border-color:#9BDBB6;color:#0B7A3D;}
  .chip-amb{background:#FDF1DA;border-color:#F0CE8A;color:#8A5D0B;}

  /* aika self-contradiction */
  .contra{
    background:var(--white);border:1px solid var(--line);border-radius:12px;
    padding:24px;margin-top:30px;
  }
  .contra > .src{
    display:block;font-family:'Roboto Mono',monospace;font-size:9px;
    letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);margin-bottom:14px;
  }
  .contra ol{margin:0;padding:0 0 0 22px;}
  .contra li{
    font-size:14px;padding:7px 9px;margin-left:-9px;border-radius:5px;
    color:var(--ink-2);line-height:1.5;
  }
  .contra li.hot{
    background:rgba(217,72,63,.09);color:var(--ink);font-weight:700;
    box-shadow:inset 2px 0 0 var(--flag);
  }

  /* template stats */
  .tmpl{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:30px;}
  .stat{background:var(--white);border:1px solid var(--line);border-radius:12px;padding:20px;}
  .stat b{
    display:block;font-size:44px;font-weight:900;line-height:1;
    letter-spacing:-.04em;margin-bottom:8px;
  }
  .stat:nth-child(1) b{color:var(--ink);}
  .stat:nth-child(2) b{color:var(--amber);}
  .stat:nth-child(3) b{color:var(--flag);}
  .stat span{font-size:12.5px;color:var(--ink-2);line-height:1.5;display:block;}

  /* the schema already exists */
  .proof{
    background:var(--slate);border-radius:12px;padding:26px 24px;margin-top:30px;color:#fff;
  }
  .proof h6{margin:0 0 4px;font-size:18px;font-weight:900;letter-spacing:-.015em;}
  .proof > .sub{margin:0 0 18px;font-size:13.5px;color:rgba(255,255,255,.6);}
  .proof-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
  .proof-col{
    background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);
    border-radius:8px;padding:14px;
  }
  .proof-col .src{
    display:block;font-family:'Roboto Mono',monospace;font-size:9px;
    letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.45);margin-bottom:9px;
  }
  .proof-col p{margin:0;font-size:13px;color:rgba(255,255,255,.78);line-height:1.65;}
  .proof-col p b{color:#4FD489;font-weight:700;}
  .proof .verdict{
    margin:18px 0 0;padding-top:16px;border-top:1px solid rgba(255,255,255,.14);
    font-size:14.5px;color:rgba(255,255,255,.75);line-height:1.6;
  }
  .proof .verdict b{color:#fff;font-weight:700;}

  /* check-it-yourself link bar */
  .linkbar{margin-top:24px;display:flex;flex-wrap:wrap;gap:9px;align-items:center;}
  .linkbar .lbl{
    font-family:'Roboto Mono',monospace;font-size:10px;letter-spacing:.1em;
    text-transform:uppercase;color:rgba(255,255,255,.42);margin-right:4px;
  }
  .linkbar a{
    font-size:12.5px;font-weight:500;color:#fff;text-decoration:none;
    border:1px solid rgba(255,255,255,.26);border-radius:20px;padding:6px 13px;
    transition:background .15s,border-color .15s;
  }
  .linkbar a:hover{background:rgba(6,169,78,.2);border-color:var(--green);}
  .linkbar a::after{content:" ↗";opacity:.5;}

  /* tiers: one per screen, labelled by who reaches it */
  .tier{border-top:2px solid var(--ink);padding-top:20px;margin-top:52px;}
  .tier:first-of-type{margin-top:34px;}
  .tier-lab{display:flex;flex-wrap:wrap;align-items:baseline;gap:10px 14px;margin-bottom:12px;}
  .tier-lab .n{
    font-family:'Roboto Mono',monospace;font-size:11px;letter-spacing:.12em;color:var(--ink-3);
