---
// Site loader. After Hours register: a single hosting moment, not a system
// boot screen. Shows a time-based greeting ("still up." / "morning." / etc.)
// and the live Bengaluru clock, then fades. ~1.2s total instead of ~2.8s.
//
// On first visit only — a sessionStorage flag short-circuits the loader on
// subsequent navigation within the same tab so it doesn't gate every page.
//
// The synchronous skip-check below MUST run before paint to avoid a one-frame
// flash of the loader on revisit.
---

<script is:inline>
  if (sessionStorage.getItem('jitesh_loader_shown')) {
    document.body.classList.remove('is-loading');
    document.body.classList.add('loader-skipped');
  }
</script>

<div class="site-loader" id="siteLoader" aria-live="polite" aria-label="Loading">
  <div class="loader-core">
    <div class="loader-greeting" id="loaderGreeting">still up.</div>
    <div class="loader-time">
      <span data-live-clock>--:--</span> IST &middot; BENGALURU
    </div>
    <div class="loader-line" aria-hidden="true"><span></span></div>
  </div>
</div>

<div class="cursor-dot" aria-hidden="true"></div>
<div class="cursor-ring" aria-hidden="true"></div>

<script>
  import '../scripts/live-clock';

  const FIRST_LOAD_KEY = 'jitesh_loader_shown';
  const skipLoader = !!sessionStorage.getItem(FIRST_LOAD_KEY);
  const loader = document.getElementById('siteLoader');
  const greetingEl = document.getElementById('loaderGreeting');

  /**
   * Pick a greeting using actual Bengaluru-local hour. The result is always
   * true (no fake "01:47" anymore) and never the same across the day.
   */
  const pickGreeting = (): string => {
    const istHourStr = new Intl.DateTimeFormat('en-GB', {
      timeZone: 'Asia/Kolkata',
      hour: '2-digit',
      hour12: false,
    }).format(new Date());
    const h = parseInt(istHourStr, 10);
    if (h >= 0 && h < 5) return 'still up.';
    if (h < 12) return 'morning.';
    if (h < 17) return 'afternoon.';
    if (h < 21) return 'evening.';
    return 'late.';
  };

  if (greetingEl) greetingEl.textContent = pickGreeting();

  if (skipLoader) {
    document.body.classList.remove('is-loading');
    if (loader) loader.setAttribute('aria-hidden', 'true');
  } else if (loader) {
    // ~1.2s total — long enough to register the greeting, short enough not
    // to gate the page. Exit slides up (CSS handles the transform).
    window.setTimeout(() => {
      loader.classList.add('is-exiting');
      window.setTimeout(() => {
        document.body.classList.remove('is-loading');
        loader.setAttribute('aria-hidden', 'true');
        try {
          sessionStorage.setItem(FIRST_LOAD_KEY, '1');
        } catch {
          /* sessionStorage unavailable; ignore */
        }
      }, 500);
    }, 1200);
  } else {
    document.body.classList.remove('is-loading');
    try {
      sessionStorage.setItem(FIRST_LOAD_KEY, '1');
    } catch {
      /* ignore */
    }
  }

  // Custom pointer cursor (desktop only) — unchanged
  const cursorDot = document.querySelector<HTMLElement>('.cursor-dot');
  const cursorRing = document.querySelector<HTMLElement>('.cursor-ring');
  const canUseCursor =
    cursorDot && cursorRing && window.matchMedia('(pointer: fine)').matches;

  if (canUseCursor) {
    let dotX = window.innerWidth / 2;
    let dotY = window.innerHeight / 2;
    let ringX = dotX;
    let ringY = dotY;

    window.addEventListener(
      'mousemove',
      (event) => {
        dotX = event.clientX;
        dotY = event.clientY;
        cursorDot.style.transform = `translate3d(${dotX}px, ${dotY}px, 0) translate(-50%, -50%)`;
      },
      { passive: true },
    );

    const renderCursor = () => {
      ringX += (dotX - ringX) * 0.18;
      ringY += (dotY - ringY) * 0.18;
      cursorRing.style.transform = `translate3d(${ringX}px, ${ringY}px, 0) translate(-50%, -50%)`;
      window.requestAnimationFrame(renderCursor);
    };

    renderCursor();
  }
</script>
