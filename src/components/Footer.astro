---
// Site footer — markup, accent links, and a small fade-in observer.
// The legacy polish CSS (`footer.footer-reveal { ... }`) only kicks in once
// the `footer-reveal` class is on the element; the script below adds it
// progressively so users without JS still see a static footer.
---

<footer>
  <div class="footer-inner">
    <div class="footer-logo">Jitesh.</div>
    <div class="footer-copy">
      <span class="footer-copy-text">
        Made with lots of overthinking and black coffee
        <span class="footer-copy-emoji">☕</span>
      </span>
    </div>
    <div class="footer-links">
      <a href="mailto:thakker.jitesh04@gmail.com">Email</a>
      <a href="https://www.linkedin.com/in/jitesh-thakker/" target="_blank" rel="me noopener noreferrer">LinkedIn</a>
      <a href="https://www.behance.net/jiteshthakker" target="_blank" rel="me noopener noreferrer">Behance</a>
    </div>
  </div>
</footer>

<script>
  const footerEl = document.querySelector<HTMLElement>('footer');
  if (footerEl) {
    footerEl.classList.add('footer-reveal');
    const footerObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            footerObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 },
    );
    footerObserver.observe(footerEl);
  }
</script>
