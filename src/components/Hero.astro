---
// Hero section. The right side hosts a terminal-style "now" status panel
// (replaces the old profile card). Live clock and a typewriter cycling
// through site-derived phrases give it perceptible life.
//
// Three.js canvas + vanilla-tilt still lazy-load via companion scripts.
---

<section class="hero" id="home">
  <canvas id="global-three-canvas" aria-hidden="true"></canvas>
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="dot"></span>
        Product Designer · Bengaluru
      </div>
      <h1 class="hero-title">
        I work on the<br />
        <span class="highlight">hard things.</span>
      </h1>
      <p class="hero-desc">
        I craft B2B product experiences — turning complex workflows into
        intuitive, scalable interfaces. 2 years in, still obsessed with the
        details.
      </p>
      <div class="hero-actions">
        <a href="#work" class="btn-solid" id="hero-cta-work">View Work ↓</a>
        <a href="#contact" class="btn-outline" id="hero-cta-contact">Say Hello</a>
      </div>
    </div>

    <div class="hero-visual">
      <aside class="hero-status-panel" aria-label="What I'm doing right now">
        <header class="hero-status-bar">
          <span class="hero-status-dots" aria-hidden="true">
            <span class="hero-status-dot"></span>
            <span class="hero-status-dot"></span>
            <span class="hero-status-dot"></span>
          </span>
          <span class="hero-status-bar-title">JITESH.EXE — ~/now</span>
        </header>

        <div class="hero-status-body">
          <div class="hero-status-line hero-status-cmd-line">
            <span class="hero-status-prompt">&gt;</span>
            <span>cat ./now.txt</span>
          </div>

          <dl class="hero-status-rows">
            <div class="hero-status-row">
              <dt>LOC</dt>
              <dd>
                Bengaluru, IN
                <span class="hero-status-clock" id="hero-clock" aria-live="off">—</span>
              </dd>
            </div>
            <div class="hero-status-row">
              <dt>DESIGNING</dt>
              <dd>catalogue systems + data workflows</dd>
            </div>
            <div class="hero-status-row">
              <dt>LISTENING</dt>
              <dd>dark industrial techno</dd>
            </div>
            <div class="hero-status-row">
              <dt>PLAYING</dt>
              <dd>story-driven games</dd>
            </div>
          </dl>

          <div class="hero-status-line hero-status-typed-line">
            <span class="hero-status-prompt">&gt;</span>
            <span class="hero-status-typed" id="hero-typed"></span><span class="hero-status-cursor" aria-hidden="true"></span>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  /* Tighter left column now that .currently-block migrated into the panel */
  .hero-content .hero-actions { margin-top: 2.5rem; }

  .hero-status-panel {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 460px;
    margin-left: auto;
    background: rgba(13, 13, 13, 0.78);
    border: 1px solid rgba(200, 169, 110, 0.22);
    box-shadow:
      0 32px 64px rgba(0, 0, 0, 0.45),
      0 0 0 1px rgba(200, 169, 110, 0.06),
      inset 0 1px 0 rgba(240, 234, 223, 0.04);
    font-family: 'DM Mono', ui-monospace, SFMono-Regular, monospace;
    color: var(--text-primary);
    backdrop-filter: blur(10px) saturate(120%);
    -webkit-backdrop-filter: blur(10px) saturate(120%);
  }

  .hero-status-bar {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 11px 18px;
    border-bottom: 1px solid rgba(240, 234, 223, 0.08);
  }

  .hero-status-dots {
    display: inline-flex;
    gap: 6px;
  }
  .hero-status-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: rgba(200, 169, 110, 0.35);
  }
  .hero-status-dot:nth-child(1) { background: rgba(200, 169, 110, 0.95); }
  .hero-status-dot:nth-child(2) { background: rgba(200, 169, 110, 0.6); }

  .hero-status-bar-title {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    text-transform: uppercase;
  }

  .hero-status-body {
    padding: 18px 18px 16px;
    display: grid;
    gap: 14px;
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .hero-status-line {
    display: flex;
    align-items: baseline;
    gap: 8px;
    color: var(--text-secondary);
  }

  .hero-status-prompt {
    color: var(--accent);
    font-weight: 500;
  }

  .hero-status-rows {
    display: grid;
    gap: 9px;
    margin: 0;
  }

  .hero-status-row {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 14px;
    align-items: baseline;
  }

  .hero-status-row dt {
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
  }

  .hero-status-row dd {
    margin: 0;
    color: var(--text-primary);
    font-size: 0.78rem;
  }

  .hero-status-clock {
    display: inline-block;
    margin-left: 6px;
    color: var(--text-secondary);
    font-size: 0.72rem;
  }
  .hero-status-clock::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    margin-right: 6px;
    vertical-align: 0.05em;
    box-shadow: 0 0 8px var(--accent);
    animation: heroClockPulse 2s ease-in-out infinite;
  }

  @keyframes heroClockPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.85); }
  }

  .hero-status-typed-line {
    border-top: 1px solid rgba(240, 234, 223, 0.06);
    padding-top: 12px;
    margin-top: 2px;
    min-height: 1.4em;
    color: var(--text-primary);
  }

  .hero-status-cursor {
    display: inline-block;
    width: 7px;
    height: 0.95em;
    background: var(--accent);
    vertical-align: text-bottom;
    margin-left: 2px;
    animation: heroCursorBlink 1.1s steps(2) infinite;
  }

  @keyframes heroCursorBlink {
    50% { opacity: 0; }
  }

  /* Respect reduced motion: still show clock + typed text, just no pulse/blink */
  @media (prefers-reduced-motion: reduce) {
    .hero-status-clock::before,
    .hero-status-cursor {
      animation: none !important;
    }
  }

  @media (max-width: 1024px) {
    .hero-status-panel {
      max-width: 100%;
      margin: 2rem 0 0;
    }
    .hero-status-row {
      grid-template-columns: 84px 1fr;
    }
  }

  @media (max-width: 480px) {
    .hero-status-body {
      padding: 16px;
      gap: 12px;
      font-size: 0.74rem;
    }
    .hero-status-row {
      grid-template-columns: 76px 1fr;
      gap: 10px;
    }
    .hero-status-row dt { font-size: 0.66rem; }
    .hero-status-row dd { font-size: 0.74rem; }
  }
</style>

<script>
  import '../scripts/hero-canvas';
  import '../scripts/tilt';
  import '../scripts/hero-status';
</script>
