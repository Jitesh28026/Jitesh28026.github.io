---
// Hero section. The right column hosts a minimal "now" meta panel using the
// same .ah-meta component as the About page, so the homepage and About read
// as the same designer's hand. Live clock ticks in actual Bengaluru time.
---

<section class="hero" id="home">
  <canvas id="global-three-canvas" aria-hidden="true"></canvas>
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="dot"></span>
        Product Designer · Bengaluru
      </div>
      <h1 class="hero-title" data-inner-voice="the easy ones bored me first.">
        I work on the<br />
        <span class="highlight">hard things.</span>
      </h1>
      <p class="hero-desc">
        I craft B2B product experiences, turning complex workflows into
        intuitive, scalable interfaces. 3.9 years in, still obsessed with the
        details.
      </p>
      <div class="hero-actions">
        <a href="#work" class="btn-solid" id="hero-cta-work">View Work ↓</a>
        <a href="#contact" class="btn-outline" id="hero-cta-contact">Say Hello</a>
      </div>
    </div>

    <aside class="hero-meta" aria-label="What I'm doing right now">
      <dl class="ah-meta">
        <div class="ah-meta-row">
          <dt>LOC</dt>
          <dd>Bengaluru &middot; <span data-live-clock>--:--</span> IST</dd>
        </div>
        <div class="ah-meta-row">
          <dt>DESIGNING</dt>
          <dd>catalogue systems + data workflows</dd>
        </div>
        <div class="ah-meta-row">
          <dt>LISTENING</dt>
          <dd>dark industrial techno</dd>
        </div>
        <div class="ah-meta-row">
          <dt>PLAYING</dt>
          <dd>story-driven games</dd>
        </div>
      </dl>
    </aside>
  </div>
</section>

<style>
  .hero-content .hero-actions { margin-top: 2.5rem; }

  /* Hero headline inner voice — same motif as the About paragraphs.
     Hover the headline and a mono italic line reveals in gold. Carries
     the After Hours craft moment into the homepage. */
  .hero-title {
    position: relative;
    cursor: default;
  }
  .hero-title::after {
    content: attr(data-inner-voice);
    display: block;
    margin-top: 1.25rem;
    padding: 0.15rem 0 0.15rem 1rem;
    border-left: 2px solid var(--accent);
    font-family: 'DM Mono', monospace;
    font-style: normal;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    letter-spacing: 0.02em;
    color: var(--accent);
    text-transform: none;
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }
  .hero-title:hover::after {
    opacity: 1;
    transform: translateY(0);
  }
  /* Touch / coarse pointers can't hover-reveal, so always show. */
  @media (hover: none), (pointer: coarse) {
    .hero-title::after { opacity: 1 !important; transform: none !important; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-title::after { transition: none !important; }
  }

  /* Hero meta — mirrors .after-hours .ah-meta in shape so the homepage and
     About share the same visual component. Wrapper holds the same translucent
     dark panel chrome the old terminal had; rows inside use ah-meta naming
     because they ARE the same component, just scoped to the hero too. */
  .hero-meta {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 460px;
    margin-left: auto;
    padding: 22px 26px;
    border: 1px solid rgba(200, 169, 110, 0.22);
    background: rgba(13, 13, 13, 0.78);
    backdrop-filter: blur(10px) saturate(120%);
    -webkit-backdrop-filter: blur(10px) saturate(120%);
  }

  .hero-meta .ah-meta {
    margin: 0;
    padding: 0;
    font-family: 'DM Mono', monospace;
    font-size: 0.78rem;
    color: var(--text-secondary);
    letter-spacing: 0.06em;
  }

  .hero-meta .ah-meta-row {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 14px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(240, 234, 223, 0.08);
    align-items: baseline;
  }

  .hero-meta .ah-meta-row:first-child { padding-top: 4px; }
  .hero-meta .ah-meta-row:last-child {
    border-bottom: 0;
    padding-bottom: 4px;
  }

  .hero-meta .ah-meta dt {
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
  }

  .hero-meta .ah-meta dd {
    margin: 0;
    color: var(--text-primary);
    font-size: 0.78rem;
  }

  @media (max-width: 1024px) {
    .hero-meta {
      max-width: 100%;
      margin: 2rem 0 0;
    }
    .hero-meta .ah-meta-row {
      grid-template-columns: 84px 1fr;
    }
  }

  @media (max-width: 480px) {
    .hero-meta {
      padding: 18px 20px;
    }
    .hero-meta .ah-meta-row {
      grid-template-columns: 76px 1fr;
      gap: 10px;
    }
    .hero-meta .ah-meta dt { font-size: 0.66rem; }
    .hero-meta .ah-meta dd { font-size: 0.74rem; }
  }
</style>

<script>
  import '../scripts/hero-canvas';
  import '../scripts/tilt';
  import '../scripts/live-clock';
</script>
