---
import { Image } from 'astro:assets';
import { workCards } from '../data/work';
---

<section class="work-section" id="work">
  <div class="section-container">
    <div class="work-header reveal">
      <div>
        <div class="section-label">Selected Work</div>
        <h2 class="section-heading">
          Projects that <span class="muted">shipped.</span>
        </h2>
      </div>
    </div>
    <div class="work-grid">
      {workCards.map((card) => (
        <a
          href={card.href}
          class="project-card reveal"
          id={card.htmlId}
          target={card.external ? '_blank' : undefined}
          rel={card.external ? 'noopener noreferrer' : undefined}
        >
          <div class="project-thumb">
            <div class={`project-thumb-inner ${card.thumbClass}`} style="background: none;">
              <Image
                src={card.thumbnail}
                alt={card.thumbnailAlt}
                widths={[400, 800, 1200]}
                sizes="(max-width: 768px) 100vw, 600px"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: left top;"
              />
              <span class="thumb-number">{card.displayNumber}</span>
            </div>
          </div>
          <div class="project-body">
            <div class="project-tags">
              {card.tags.map((tag) => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>
            <div class="project-name">{card.title}</div>
            <p class="project-desc">{card.summary}</p>
          </div>
          <div class="project-arrow">↗</div>
        </a>
      ))}
    </div>
  </div>
</section>
